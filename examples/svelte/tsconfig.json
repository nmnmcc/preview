{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "types": [
      "svelte",
      "vite/client"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.svelte",
    "svelte.config.js",
    "vite.config.ts"
  ]
}
