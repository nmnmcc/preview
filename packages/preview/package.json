{
  "name": "@nmnmcc/preview",
  "version": "0.2.0",
  "description": "Define, run, and inspect UI previews with Vite",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": [
    "./dist/main.mjs",
    "./dist/runner.mjs"
  ],
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "bin": "./dist/main.mjs",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "browser": {
          "types": "./dist/browser.d.mts",
          "default": "./dist/browser.mjs"
        },
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "./application": "./dist/application.mjs",
      "./viewports": "./dist/viewports.mjs",
      "./package.json": "./package.json",
      "./internal/runner": {
        "types": "./dist/runner.d.mts",
        "default": "./dist/runner.mjs"
      }
    }
  },
  "scripts": {
    "build": "yarn --cwd ../.. tsdown -F @nmnmcc/preview",
    "typecheck": "yarn run -T tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform-browser": "4.0.0-beta.98",
    "@effect/platform-node-shared": "4.0.0-beta.98",
    "effect": "4.0.0-beta.98",
    "picocolors": "^1.1.1"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.98",
    "playwright": "^1.61.0",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.98",
    "playwright": "1.61.1",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "exports": {
    ".": {
      "browser": {
        "development": "./src/browser.ts",
        "types": "./dist/browser.d.mts",
        "default": "./dist/browser.mjs"
      },
      "development": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./application": {
      "development": "./src/Application.ts",
      "default": "./dist/application.mjs"
    },
    "./viewports": {
      "development": "./src/Viewports.ts",
      "default": "./dist/viewports.mjs"
    },
    "./package.json": "./package.json",
    "./internal/runner": {
      "development": "./src/internal/browser/main.ts",
      "types": "./dist/runner.d.mts",
      "default": "./dist/runner.mjs"
    }
  }
}
