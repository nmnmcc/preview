{
  "name": "@nmnmcc/preview-vue",
  "version": "0.2.0",
  "description": "Define Vue previews for @nmnmcc/preview",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "yarn --cwd ../.. tsdown -F @nmnmcc/preview-vue",
    "test": "vitest run",
    "typecheck": "yarn run -T tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nmnmcc/preview": "workspace:^"
  },
  "peerDependencies": {
    "vue": "^3.2.25"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "6.0.7",
    "playwright": "1.61.1",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "vue": "3.5.39"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  }
}
