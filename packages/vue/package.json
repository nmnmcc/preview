{
  "name": "@nmnmcc/preview-vue",
  "version": "0.0.1",
  "description": "Define Vue previews for @nmnmcc/preview",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "yarn --cwd ../.. tsdown -F @nmnmcc/preview-vue",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nmnmcc/preview": "workspace:^"
  },
  "peerDependencies": {
    "vue": "^3.2.25"
  },
  "devDependencies": {
    "typescript": "7.0.2",
    "vue": "3.5.39"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  }
}
