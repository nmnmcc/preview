{
  "name": "@nmnmcc/preview-cli",
  "version": "0.0.1",
  "description": "Effect-powered CLI for generating @nmnmcc/preview artifacts",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": [
    "./dist/main.mjs"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "yarn --cwd ../.. tsdown -F @nmnmcc/preview-cli",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform-node-shared": "4.0.0-beta.98",
    "@nmnmcc/preview": "workspace:^",
    "effect": "4.0.0-beta.98"
  },
  "peerDependencies": {
    "playwright": "^1.61.0",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.98",
    "playwright": "1.61.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "bin": {
    "preview": "./dist/main.mjs"
  }
}
