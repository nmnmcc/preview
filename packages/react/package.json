{
  "name": "@nmnmcc/preview-react",
  "version": "0.1.0",
  "description": "Define React previews for @nmnmcc/preview",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "yarn --cwd ../.. tsdown -F @nmnmcc/preview-react",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nmnmcc/preview": "workspace:^"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "7.0.2"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  }
}
