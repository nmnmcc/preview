{
  "name": "@nmnmcc/preview-react",
  "version": "1.0.0",
  "description": "Define React previews for @nmnmcc/preview",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nmnmcc/preview.git",
    "directory": "packages/react"
  },
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "yarn --cwd ../.. tsdown -F @nmnmcc/preview-react",
    "test": "vitest run",
    "typecheck": "yarn run -T tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nmnmcc/preview": "workspace:^"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "playwright": "1.61.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  }
}
